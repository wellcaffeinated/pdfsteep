PUID=1000
PGID=1000
TZ=Etc/UTC

# host path bind-mounted to /data in the container
DATA_DIR=./data

# paths *inside* the container that get watched/written to; both default
# under /data, but can be set equal (e.g. IN_DIR=OUT_DIR=/data) for
# in-place conversion out of a single shared directory
IN_DIR=/data/in
OUT_DIR=/data/out
